function VenyxUI:CreateWindow(title, options)
    options    = options or {}
    local toggleKey = options.ToggleKey or Enum.KeyCode.Insert

    local savedData   = loadConfig()
    local connections = {}
    local function track(conn) connections[#connections + 1] = conn; return conn end

    -- AutoSave preference: a previously-saved choice (from the Config tab's
    -- master toggle) overrides whatever was passed into CreateWindow, so it
    -- survives between sessions.
    local autoSave = options.AutoSave ~= false
    if savedData["_autosave_enabled"] ~= nil then
        autoSave = savedData["_autosave_enabled"] == true
    end

    -- Registry of every saveable control (toggle/slider/dropdown/keybind),
    -- in the order they were created, used to populate the Config tab's
    -- "what to auto-save" list.
    local saveRegistry = {}

    -- Keys excluded from auto-save even when the master switch is on,
    -- restored from the previous session.
    local excludedKeys = {}
    do
        local list = savedData["_autosave_excluded"]
        if type(list) == "table" then
            for _, k in ipairs(list) do excludedKeys[k] = true end
        end
    end

    -- Only one dropdown open at a time
    local activeDropdown = nil

    -- ── ScreenGui ───────────────────────────
    local ScreenGui = Create("ScreenGui", {
        Name            = "VenyxUI",
        ResetOnSpawn    = false,
        ZIndexBehavior  = Enum.ZIndexBehavior.Global,
        IgnoreGuiInset  = true,
    })
    local ok = pcall(function() ScreenGui.Parent = CoreGui end)
    if not ok then
        local pg = LocalPlayer:WaitForChild("PlayerGui", 5)
        if pg then ScreenGui.Parent = pg else
            warn("[VenyxUI] Could not parent ScreenGui.")
        end
    end

    -- Invisible full-screen button used to close an open dropdown.
    -- Sits ABOVE the window's own content (ZIndex 50) but BELOW the
    -- dropdown list itself (ZIndex 100+), so clicks on the actual
    -- dropdown options are caught by the options first, while any
    -- other click anywhere on screen closes the dropdown instead of
    -- racing with it.
    local DropdownCatcher = Create("TextButton", {
        Name             = "DropdownCatcher",
        Size             = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        AutoButtonColor  = false,
        Text             = "",
        ZIndex           = 50,
        Visible          = false,
        Parent           = ScreenGui,
    })
    track(DropdownCatcher.MouseButton1Click:Connect(function()
        if activeDropdown then
            activeDropdown.close()
            activeDropdown = nil
        end
        DropdownCatcher.Visible = false
    end))

    -- ── Window ──────────────────────────────
    local BASE_W, BASE_H = 480, 490

    local Window = Create("Frame", {
        Name             = "Window",
        Size             = UDim2.new(0, BASE_W, 0, BASE_H),
        Position         = UDim2.new(0.5, -BASE_W / 2, 0.5, -BASE_H / 2),
        BackgroundColor3 = Theme.Surface,
        BorderSizePixel  = 0,
        ClipsDescendants = false,   -- must be false so DropList overlay works
        Parent           = ScreenGui,
    }, {
        Create("UICorner",         { CornerRadius = UDim.new(0, 14) }),
        Create("UIStroke",         { Color = Theme.Border, Thickness = 1,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border }),
        Create("UISizeConstraint", { MaxSize = Vector2.new(480, 700) }),
    })

    -- Scales the *entire* window (and everything inside it, including text,
    -- toggles, sliders) down uniformly on small/mobile screens, instead of
    -- letting a fixed 480x490 window overflow a phone's viewport.
    local WindowScale = Create("UIScale", { Scale = 1, Parent = Window })

    local function clampWindowPosition(pos)
        local camera = workspace.CurrentCamera
        if not camera then return pos end
        local vp = camera.ViewportSize
        local sz = Window.AbsoluteSize
        local x  = math.clamp(pos.X.Offset, 0, math.max(0, vp.X - sz.X))
        local y  = math.clamp(pos.Y.Offset, 0, math.max(0, vp.Y - sz.Y))
        return UDim2.new(0, x, 0, y)
    end

    local function updateResponsiveScale(recenter)
        local camera = workspace.CurrentCamera
        if not camera then return end
        local vp = camera.ViewportSize
        if vp.X <= 0 or vp.Y <= 0 then return end

        -- Leave room around the edges (8% width, 15% height) so the window
        -- never touches the screen border, and never scale up past 1x.
        local scale = math.clamp(
            math.min(vp.X * 0.92 / BASE_W, vp.Y * 0.85 / BASE_H, 1),
            0.55, 1
        )
        WindowScale.Scale = scale

        if recenter then
            local w, h = BASE_W * scale, BASE_H * scale
            Window.Position = UDim2.new(0, (vp.X - w) / 2, 0, (vp.Y - h) / 2)
        else
            Window.Position = clampWindowPosition(Window.Position)
        end
    end

    updateResponsiveScale(true)

    do
        local camera = workspace.CurrentCamera
        if camera then
            track(camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
                updateResponsiveScale(false)
            end))
        end
    end

    -- Drop shadow
