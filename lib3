    -- Version badge
    Create("TextLabel", {
        Size             = UDim2.new(0, 50, 0, 20),
        Position         = UDim2.new(1, -110, 0.5, -10),
        BackgroundColor3 = Color3.fromRGB(40, 34, 80),
        Text             = "v2.5",
