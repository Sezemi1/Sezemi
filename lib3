        Font             = Enum.Font.GothamBold,
        ZIndex           = 4,
        Parent           = TitleBar,
    }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }) })

    -- ── Tab Bar ─────────────────────────────
    -- Use a plain clipping Frame + inner sliding Frame instead of ScrollingFrame.
    -- ScrollingFrame with AutomaticCanvasSize has a race condition: the canvas
    -- size is set before AutomaticSize on the tab buttons resolves, so the
    -- buttons end up invisible. A plain Frame with manual Position sliding
