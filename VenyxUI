    -- ── Mini Square Toggle ───────────────────
    local MiniToggle = Create("TextButton", {
        Name     = "MiniToggle",
        Size     = UDim2.new(0, 42, 0, 42),
        Position = UDim2.new(0.5, -21, 0, 16),
        BackgroundColor3 = Theme.Surface2,
        Text     = "≡",
        TextColor3 = Color3.fromRGB(157, 143, 255),
        TextSize   = 20,
        Font   = Enum.Font.GothamBold,
        Visible  = false,
        ZIndex   = 10,
        Parent   = ScreenGui,
    }, {
        Create("UICorner",  { CornerRadius = UDim.new(0, 10) }),
        Create("UIStroke",  { Color = Theme.Border, Thickness = 1 }),
    })

    -- ── Draggable window ─────────────────────
    do
        local dragging  = false
        local dragInput, dragStart, startPos

        local function clampToScreen(pos)
            local viewport = workspace.CurrentCamera.ViewportSize
            local size     = Window.AbsoluteSize
            local minX, maxX = 0, viewport.X - size.X
            local minY, maxY = 0, viewport.Y - size.Y
            local x = math.clamp(pos.X.Offset, minX, math.max(minX, maxX))
            local y = math.clamp(pos.Y.Offset, minY, math.max(minY, maxY))
            return UDim2.new(0, x, 0, y)
        end

        local function updateDrag(input)
            local delta  = input.Position - dragStart
            local rawPos = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
            Window.Position = clampToScreen(rawPos)
        end

        track(TitleBar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging  = true
                dragStart = input.Position
                startPos  = Window.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end))

        track(TitleBar.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement
            or input.UserInputType == Enum.UserInputType.Touch then
                dragInput = input
            end
        end))

        track(UserInputService.InputChanged:Connect(function(input)
            if dragging and input == dragInput then
                updateDrag(input)
            end
        end))
    end

    -- ── Visibility ──────────────────────────
    local visible = true

    local function hideWindow()
        if autoSave then
            FooterText.Text = "VenyxUI — config auto-saved"
            Notify(ScreenGui, "Config auto-saved!", Theme.Accent)
        end
        Tween(Window, { Position = UDim2.new(
            Window.Position.X.Scale, Window.Position.X.Offset,
            Window.Position.Y.Scale, Window.Position.Y.Offset + 8
        )})
        task.delay(0.1, function()
            Window.Visible   = false
            MiniToggle.Visible = true
        end)
        visible = false
    end

    local function showWindow()
        Window.Visible   = true
        MiniToggle.Visible = false
        Tween(Window, { Position = UDim2.new(
            Window.Position.X.Scale, Window.Position.X.Offset,
            Window.Position.Y.Scale, Window.Position.Y.Offset - 8
        )})
        visible = true
        Notify(ScreenGui, "UI opened", Theme.Accent)
    end

    track(CloseBtn.MouseButton1Click:Connect(hideWindow))
    track(MiniToggle.MouseButton1Click:Connect(showWindow))

    -- FIX: Window toggle key — was broken because `processed` was never false for
    -- keystrokes when listening inside the keybind handler. Use a dedicated connection.
    track(UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == toggleKey then
            if visible then hideWindow() else showWindow() end
        end
    end))

    -- Hover effects
    track(CloseBtn.MouseEnter:Connect(function()
        Tween(CloseBtn, { BackgroundColor3 = Color3.fromRGB(120, 30, 30) })
    end))
    track(CloseBtn.MouseLeave:Connect(function()
        Tween(CloseBtn, { BackgroundColor3 = Color3.fromRGB(80, 20, 20) })
    end))
    track(MiniToggle.MouseEnter:Connect(function()
        Tween(MiniToggle, { BackgroundColor3 = Theme.Surface3 })
    end))
    track(MiniToggle.MouseLeave:Connect(function()
        Tween(MiniToggle, { BackgroundColor3 = Theme.Surface2 })
    end))

    -- FIX: Close dropdown when clicking anywhere outside it
    track(UserInputService.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            if activeDropdown then
                activeDropdown.close()
                activeDropdown = nil
            end
        end
    end))

    -- ══════════════════════════════════════
    --  TAB SYSTEM
    -- ══════════════════════════════════════
    local tabs      = {}
    local activeTab = nil
    local tabIndex  = 0

    local WindowObj = { _saved = savedData, _screenGui = ScreenGui, _window = Window }

    function WindowObj:AddTab(name, icon)
        tabIndex = tabIndex + 1
        local myIndex = tabIndex

        local TabBtn = Create("TextButton", {
            Size          = UDim2.new(0, 0, 1, 0),
            AutomaticSize = Enum.AutomaticSize.X,
            BackgroundTransparency = 1,
            Text          = (icon and (icon .. " ") or "") .. name,
            TextColor3    = Theme.TextMuted,
            TextSize      = 12,
            Font          = Enum.Font.GothamSemibold,
            LayoutOrder   = myIndex,
            ZIndex        = 4,
            Parent        = TabBar,
        }, {
            Create("UIPadding", {
                PaddingLeft  = UDim.new(0, 12),
                PaddingRight = UDim.new(0, 12),
            }),
        })

        local Underline = Create("Frame", {
            Size             = UDim2.new(1, 0, 0, 2),
            Position         = UDim2.new(0, 0, 1, -2),
            BackgroundColor3 = Theme.Accent,
            BorderSizePixel  = 0,
            BackgroundTransparency = 1,
            ZIndex           = 5,
            Parent           = TabBtn,
        })

        local TabFrame = Create("Frame", {
            Name          = "Tab_" .. name,
            Size          = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Visible       = false,
            LayoutOrder   = myIndex,
            Parent        = ContentArea,
        }, {
            Create("UIListLayout", {
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding   = UDim.new(0, 4),
            }),
        })

        local function activate()
            if activeTab then
                Tween(activeTab._btn,  { TextColor3 = Theme.TextMuted })
                Tween(activeTab._line, { BackgroundTransparency = 1 })
                activeTab._frame.Visible = false
            end
            Tween(TabBtn,    { TextColor3 = Color3.fromRGB(157, 143, 255) })
            Tween(Underline, { BackgroundTransparency = 0 })
            TabFrame.Visible = true
            activeTab = { _btn = TabBtn, _line = Underline, _frame = TabFrame }
        end

        track(TabBtn.MouseButton1Click:Connect(activate))
        if myIndex == 1 then activate() end

        -- ── Tab Object ──────────────────────
        local Tab = {}

        -- ── Section ────────────────────────
        function Tab:AddSection(label)
            local sectionIndex = #TabFrame:GetChildren()
            Create("TextLabel", {
                Size     = UDim2.new(1, 0, 0, 26),
                BackgroundTransparency = 1,
                Text     = label:upper(),
                TextColor3 = Theme.TextDim,
                TextSize   = 10,
                Font   = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Left,
                LayoutOrder = sectionIndex + 1,
                Parent  = TabFrame,
            }, {
                Create("UIPadding", { PaddingLeft = UDim.new(0, 4), PaddingTop = UDim.new(0, 6) }),
            })
        end

        -- ── Row helper ──────────────────────
        local function makeRow(order, height)
            height = height or 42
            local row = Create("Frame", {
                Size             = UDim2.new(1, 0, 0, height),
                BackgroundColor3 = Theme.Surface2,
                BorderSizePixel  = 0,
                LayoutOrder      = order or (#TabFrame:GetChildren() + 1),
                ZIndex           = 4,
                Parent           = TabFrame,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Create("UIStroke", { Color = Theme.Border, Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }),
            })
            track(row.MouseEnter:Connect(function()
                Tween(row, { BackgroundColor3 = Theme.Surface3 })
            end))
            track(row.MouseLeave:Connect(function()
                Tween(row, { BackgroundColor3 = Theme.Surface2 })
            end))
            return row
        end

        -- ── Toggle ──────────────────────────
        function Tab:AddToggle(label, description, default, callback)
            local key      = label:lower():gsub(" ", "_")
            local rowHeight = (description and description ~= "") and 52 or 42
            local row       = makeRow(#TabFrame:GetChildren() + 1, rowHeight)

            Create("TextLabel", {
                Size     = UDim2.new(0.6, -50, 0, 18),
                Position = UDim2.new(0, 12, 0.2, 0),
                BackgroundTransparency = 1,
                Text     = label,
                TextColor3 = Theme.Text,
                TextSize   = 13,
                Font   = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = row,
            })

            if description and description ~= "" then
                Create("TextLabel", {
                    Size     = UDim2.new(0.75, -50, 0, 14),
                    Position = UDim2.new(0, 12, 0, 24),
                    BackgroundTransparency = 1,
                    Text     = description,
                    TextColor3 = Theme.TextDim,
                    TextSize   = 11,
                    Font   = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    ZIndex = 5,
                    Parent = row,
                })
            end

            local Track = Create("Frame", {
                Size     = UDim2.new(0, 36, 0, 20),
                Position = UDim2.new(1, -48, 0.5, -10),
                BackgroundColor3 = Theme.Surface3,
                BorderSizePixel  = 0,
                ZIndex   = 5,
                Parent   = row,
            }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local Thumb = Create("Frame", {
                Size     = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(0, 2, 0.5, -7),
                BackgroundColor3 = Theme.TextDim,
                BorderSizePixel  = 0,
                ZIndex   = 6,
                Parent   = Track,
            }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local savedState = savedData[key]
            local state = (savedState == nil) and (default == true) or (savedState == true)

            local function setState(val, silent)
                state = val
                if val then
                    Tween(Track, { BackgroundColor3 = Theme.Accent })
                    Tween(Thumb, { Position = UDim2.new(0, 20, 0.5, -7), BackgroundColor3 = Color3.fromRGB(255, 255, 255) })
                else
                    Tween(Track, { BackgroundColor3 = Theme.Surface3 })
                    Tween(Thumb, { Position = UDim2.new(0, 2, 0.5, -7), BackgroundColor3 = Theme.TextDim })
                end
                if not silent then
                    if autoSave then
                        savedData[key] = val
                        saveConfig(savedData)
                    end
                    if callback then callback(val) end
                    Notify(ScreenGui, label .. ": " .. (val and "Enabled" or "Disabled"),
                        val and Theme.Success or Theme.Danger)
                end
            end

            setState(state, true)

            local ToggleBtn = Create("TextButton", {
                Size     = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text     = "",
                ZIndex   = 7,
                Parent   = row,
            })
            track(ToggleBtn.MouseButton1Click:Connect(function()
                setState(not state)
            end))

            return { SetValue = setState, GetValue = function() return state end }
        end

        -- ── Slider ──────────────────────────
        -- FIX: Touch support added; ValLabel update made reliable; min==max guard added.
        function Tab:AddSlider(label, min, max, default, suffix, callback)
            local key      = "slider_" .. label:lower():gsub(" ", "_")
            local row      = makeRow(#TabFrame:GetChildren() + 1, 52)
            suffix         = suffix or ""

            -- Guard against degenerate range
            if min >= max then max = min + 1 end

            local savedVal = savedData[key]
            local value    = math.clamp(
                (savedVal ~= nil) and savedVal or default,
                min, max
            )

            Create("TextLabel", {
                Size     = UDim2.new(0.6, 0, 0, 18),
                Position = UDim2.new(0, 12, 0, 8),
                BackgroundTransparency = 1,
                Text     = label,
                TextColor3 = Theme.Text,
                TextSize   = 13,
                Font   = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = row,
            })

            -- FIX: ValLabel is explicitly sized so it cannot be zero-width/height.
            local ValLabel = Create("TextLabel", {
                Size     = UDim2.new(0, 80, 0, 18),
                Position = UDim2.new(1, -92, 0, 8),
                BackgroundTransparency = 1,
                Text     = tostring(value) .. suffix,
                TextColor3 = Color3.fromRGB(157, 143, 255),
                TextSize   = 12,
                Font   = Enum.Font.GothamBold,
                TextXAlignment = Enum.TextXAlignment.Right,
                ZIndex = 5,
                Parent = row,
            })

            local TrackBg = Create("Frame", {
                Size     = UDim2.new(1, -24, 0, 4),
                Position = UDim2.new(0, 12, 1, -16),
                BackgroundColor3 = Theme.Surface3,
                BorderSizePixel  = 0,
                ZIndex   = 5,
                Parent   = row,
            }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local initRel   = (value - min) / (max - min)

            local TrackFill = Create("Frame", {
                Size     = UDim2.new(initRel, 0, 1, 0),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel  = 0,
                ZIndex   = 6,
                Parent   = TrackBg,
            }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local SliderThumb = Create("Frame", {
                Size     = UDim2.new(0, 14, 0, 14),
                Position = UDim2.new(initRel, -7, 0.5, -7),
                BackgroundColor3 = Theme.Accent,
                BorderSizePixel  = 0,
                ZIndex   = 7,
                Parent   = TrackBg,
            }, { Create("UICorner", { CornerRadius = UDim.new(1, 0) }) })

            local dragging = false

            local function updateSlider(inputPos)
                local rel = math.clamp(
                    (inputPos.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X,
                    0, 1
                )
                local newVal = math.round(min + (max - min) * rel)
                if newVal ~= value then
                    value = newVal
                    -- FIX: Assign text directly first (instant) then tween visuals
                    ValLabel.Text = tostring(value) .. suffix
                    Tween(TrackFill,   { Size     = UDim2.new(rel, 0, 1, 0) })
                    Tween(SliderThumb, { Position = UDim2.new(rel, -7, 0.5, -7) })
                    if autoSave then
                        savedData[key] = value
                        saveConfig(savedData)
                    end
                    if callback then callback(value) end
                end
            end

            -- FIX: Also handle Touch input type
            track(TrackBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = true
                    updateSlider(input.Position)
                end
            end))

            track(UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1
                or input.UserInputType == Enum.UserInputType.Touch then
                    dragging = false
                end
            end))

            track(UserInputService.InputChanged:Connect(function(input)
                if dragging and (
                    input.UserInputType == Enum.UserInputType.MouseMovement or
                    input.UserInputType == Enum.UserInputType.Touch
                ) then
                    updateSlider(input.Position)
                end
            end))

            return {
                GetValue = function() return value end,
                SetValue = function(val)
                    val   = math.clamp(math.round(val), min, max)
                    value = val
                    local rel = (val - min) / (max - min)
                    ValLabel.Text = tostring(val) .. suffix
                    Tween(TrackFill,   { Size     = UDim2.new(rel, 0, 1, 0) })
                    Tween(SliderThumb, { Position = UDim2.new(rel, -7, 0.5, -7) })
                    if autoSave then savedData[key] = val; saveConfig(savedData) end
                    if callback then callback(val) end
                end,
            }
        end

        -- ── Dropdown ────────────────────────
        -- FIX: Parented to ScreenGui so it renders above everything.
        --       Only one dropdown open at a time. Outside-click closes it.
        --       Positioned dynamically from DropBtn's AbsolutePosition.
        --       Scrollable when list is long. Arrow flips on open/close.
        function Tab:AddDropdown(label, opts, default, callback)
            local key      = "dd_" .. label:lower():gsub(" ", "_")
            local row      = makeRow(#TabFrame:GetChildren() + 1)

            local savedVal = savedData[key]
            local selected = savedVal or default or opts[1]

            Create("TextLabel", {
                Size     = UDim2.new(0.45, 0, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text     = label,
                TextColor3 = Theme.Text,
                TextSize   = 13,
                Font   = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = row,
            })

            local DropBtn = Create("TextButton", {
                Size     = UDim2.new(0, 140, 0, 28),
                Position = UDim2.new(1, -152, 0.5, -14),
                BackgroundColor3 = Theme.Surface3,
                Text     = selected .. "  ▾",
                TextColor3 = Theme.Text,
                TextSize   = 12,
                Font   = Enum.Font.GothamSemibold,
                ZIndex = 5,
                Parent = row,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Create("UIStroke", { Color = Theme.Border, Thickness = 1 }),
            })

            -- FIX: DropList parented to ScreenGui at ZIndex 100 — never behind anything
            local MAX_VISIBLE  = 6
            local ITEM_HEIGHT  = 30
            local listHeight   = math.min(#opts, MAX_VISIBLE) * ITEM_HEIGHT

            local DropList = Create("ScrollingFrame", {
                Size              = UDim2.new(0, 140, 0, 0),
                Position          = UDim2.new(0, 0, 0, 0),  -- set dynamically on open
                BackgroundColor3  = Theme.Surface2,
                BorderSizePixel   = 0,
                ClipsDescendants  = true,
                ZIndex            = 100,
                Visible           = false,
                ScrollBarThickness = (#opts > MAX_VISIBLE) and 3 or 0,
                ScrollBarImageColor3 = Theme.Accent,
                CanvasSize        = UDim2.new(0, 0, 0, #opts * ITEM_HEIGHT),
                Parent            = ScreenGui,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Create("UIStroke", { Color = Theme.Border, Thickness = 1 }),
                Create("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder }),
            })

            for i, opt in ipairs(opts) do
                local optBtn = Create("TextButton", {
                    Size     = UDim2.new(1, 0, 0, ITEM_HEIGHT),
                    BackgroundTransparency = 1,
                    Text     = opt,
                    TextColor3 = (opt == selected) and Theme.Accent or Theme.TextMuted,
                    TextSize   = 12,
                    Font   = Enum.Font.GothamSemibold,
                    LayoutOrder = i,
                    ZIndex   = 101,
                    Parent   = DropList,
                })

                track(optBtn.MouseEnter:Connect(function()
                    if optBtn.Text ~= selected then
                        Tween(optBtn, { TextColor3 = Theme.Text })
                    end
                end))
                track(optBtn.MouseLeave:Connect(function()
                    optBtn.TextColor3 = (optBtn.Text == selected) and Theme.Accent or Theme.TextMuted
                end))

                track(optBtn.MouseButton1Click:Connect(function()
                    selected      = opt
                    DropBtn.Text  = opt .. "  ▾"
                    -- Update all option colours
                    for _, c in ipairs(DropList:GetChildren()) do
                        if c:IsA("TextButton") then
                            c.TextColor3 = (c.Text == opt) and Theme.Accent or Theme.TextMuted
                        end
                    end
                    -- Close
                    Tween(DropList, { Size = UDim2.new(0, 140, 0, 0) }, TweenInfo_Fast)
                    task.delay(0.18, function() DropList.Visible = false end)
                    activeDropdown = nil
                    if autoSave then savedData[key] = opt; saveConfig(savedData) end
                    if callback then callback(opt) end
                    Notify(ScreenGui, label .. ": " .. opt, Theme.Accent)
                end))
            end

            local open = false

            local function closeDropdown()
                open = false
                DropBtn.Text = selected .. "  ▾"
                Tween(DropList, { Size = UDim2.new(0, 140, 0, 0) }, TweenInfo_Fast)
                task.delay(0.18, function() DropList.Visible = false end)
                activeDropdown = nil
            end

            track(DropBtn.MouseButton1Click:Connect(function()
                -- Close any other open dropdown first
                if activeDropdown and activeDropdown.close ~= closeDropdown then
                    activeDropdown.close()
                end

                open = not open
                if open then
                    -- FIX: Compute absolute screen position of the button
                    local btnPos  = DropBtn.AbsolutePosition
                    local btnSize = DropBtn.AbsoluteSize
                    local viewport = workspace.CurrentCamera.ViewportSize

                    -- Decide whether to open upward or downward
                    local spaceBelow = viewport.Y - (btnPos.Y + btnSize.Y)
                    local openUp     = spaceBelow < listHeight + 8

                    local posY = openUp
                        and (btnPos.Y - listHeight - 4)
                        or  (btnPos.Y + btnSize.Y + 4)

                    DropList.Position = UDim2.new(0, btnPos.X, 0, posY)
                    DropList.Size     = UDim2.new(0, 140, 0, 0)
                    DropList.Visible  = true
                    DropBtn.Text      = selected .. "  ▴"
                    Tween(DropList, { Size = UDim2.new(0, 140, 0, listHeight) }, TweenInfo_Fast)
                    activeDropdown = { close = closeDropdown }
                else
                    closeDropdown()
                end
            end))

            return {
                GetValue = function() return selected end,
                SetValue = function(val)
                    selected     = val
                    DropBtn.Text = val .. "  ▾"
                    for _, c in ipairs(DropList:GetChildren()) do
                        if c:IsA("TextButton") then
                            c.TextColor3 = (c.Text == val) and Theme.Accent or Theme.TextMuted
                        end
                    end
                    if autoSave then savedData[key] = val; saveConfig(savedData) end
                    if callback then callback(val) end
                end,
            }
        end

        -- ── Button ──────────────────────────
        function Tab:AddButton(label, color, callback)
            local row  = makeRow(#TabFrame:GetChildren() + 1)
            color = color or Theme.Accent

            local Btn = Create("TextButton", {
                Size     = UDim2.new(1, -24, 0, 30),
                Position = UDim2.new(0, 12, 0.5, -15),
                BackgroundColor3 = color,
                Text     = label,
                TextColor3 = Color3.fromRGB(255, 255, 255),
                TextSize   = 13,
                Font   = Enum.Font.GothamSemibold,
                ZIndex = 5,
                Parent = row,
            }, { Create("UICorner", { CornerRadius = UDim.new(0, 6) }) })

            track(Btn.MouseEnter:Connect(function()
                Tween(Btn, { BackgroundColor3 = color:Lerp(Color3.fromRGB(255, 255, 255), 0.1) })
            end))
            track(Btn.MouseLeave:Connect(function()
                Tween(Btn, { BackgroundColor3 = color })
            end))
            track(Btn.MouseButton1Click:Connect(function()
                if callback then callback() end
            end))
        end

        -- ── Keybind ─────────────────────────
        -- FIX 1: Pressing the bound key now fires callback (it was only fired on assignment).
        -- FIX 2: Each re-bind properly disconnects the previous listener — no duplicate fires.
        function Tab:AddKeybind(label, default, callback)
            local key         = "kb_" .. label:lower():gsub(" ", "_")
            local savedKey    = savedData[key]
            local currentKey  = (savedKey and Enum.KeyCode[savedKey]) or default
            local listening   = false
            local pressConn   = nil   -- FIX: track press-listener so we can swap it

            local row = makeRow(#TabFrame:GetChildren() + 1)

            Create("TextLabel", {
                Size     = UDim2.new(0.5, 0, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text     = label,
                TextColor3 = Theme.Text,
                TextSize   = 13,
                Font   = Enum.Font.GothamSemibold,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 5,
                Parent = row,
            })

            local KeyBtn = Create("TextButton", {
                Size     = UDim2.new(0, 120, 0, 26),
                Position = UDim2.new(1, -132, 0.5, -13),
                BackgroundColor3 = Theme.Surface3,
                Text     = currentKey and currentKey.Name or "NONE",
                TextColor3 = Color3.fromRGB(157, 143, 255),
                TextSize   = 11,
                Font   = Enum.Font.GothamBold,
                ZIndex = 5,
                Parent = row,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Create("UIStroke", { Color = Theme.Border, Thickness = 1 }),
            })

            -- FIX: Wire up the press-action listener for the current key.
            local function bindPressListener(kc)
                if pressConn then pressConn:Disconnect() end
                if not kc or not callback then return end
                pressConn = track(UserInputService.InputBegan:Connect(function(input, processed)
                    if not processed and not listening and input.KeyCode == kc then
                        callback(kc)
                    end
                end))
            end

            bindPressListener(currentKey)

            -- Click = enter listen mode
            track(KeyBtn.MouseButton1Click:Connect(function()
                listening        = true
                KeyBtn.Text      = "..."
                KeyBtn.TextColor3 = Theme.Warning
            end))

            -- FIX: Single InputBegan for capturing the new key.
            -- Old code added a new connection every click → callbacks multiplied.
            track(UserInputService.InputBegan:Connect(function(input, processed)
                if not listening then return end
                if processed then return end
                if input.UserInputType ~= Enum.UserInputType.Keyboard then return end

                currentKey        = input.KeyCode
                KeyBtn.Text       = currentKey.Name
                KeyBtn.TextColor3 = Color3.fromRGB(157, 143, 255)
                listening         = false

                if autoSave then savedData[key] = currentKey.Name; saveConfig(savedData) end
                bindPressListener(currentKey)  -- rebind press listener to new key
                Notify(ScreenGui, label .. " bound to " .. currentKey.Name, Theme.Accent)
            end))
        end

        -- ── Label ───────────────────────────
        function Tab:AddLabel(text)
            local rowOrder = #TabFrame:GetChildren() + 1
            Create("TextLabel", {
                Size     = UDim2.new(1, 0, 0, 28),
                BackgroundColor3 = Theme.Surface2,
                Text     = text,
                TextColor3 = Theme.TextMuted,
                TextSize   = 12,
                Font   = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                LayoutOrder = rowOrder,
                ZIndex = 5,
                Parent  = TabFrame,
            }, {
                Create("UICorner", { CornerRadius = UDim.new(0, 6) }),
                Create("UIPadding", { PaddingLeft = UDim.new(0, 12) }),
            })
        end

        return Tab
    end

    -- ── Window-level API ────────────────────
    function WindowObj:Notify(msg, color, duration)
        Notify(ScreenGui, msg, color, duration)
    end

    -- FIX: Destroy now also cleans up every tracked connection to prevent leaks.
    function WindowObj:Destroy()
        for _, conn in ipairs(connections) do
            pcall(function() conn:Disconnect() end)
        end
        connections = {}
        ScreenGui:Destroy()
    end

    return WindowObj
end

return VenyxUI


