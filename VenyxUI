--[[
    VenyxUI Library v2.1
    A lightweight, fast Roblox UI library — no loading screen.
    Fixed: dropdown z-index/clipping/positioning, multi-dropdown, outside-click close,
           slider text update, slider touch support, keybind press detection,
           tab scroll only when needed, event cleanup, duplicate callback prevention,
           tab overflow indicator.

    USAGE:
        local VenyxUI = loadstring(game:HttpGet("YOUR_URL_HERE"))()
        local Window = VenyxUI:CreateWindow("My Script")
        local Tab = Window:AddTab("Combat", "⚔")
        Tab:AddToggle("Aimbot", "Locks aim to nearest target", false, function(val)
            print("Aimbot:", val)
        end)
]]

