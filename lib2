    -- Thin spacer as first child gives the 8px left gap without touching canvas calc
    Create("Frame", {
        Size             = UDim2.new(0, 8, 1, 0),
        BackgroundTransparency = 1,
        LayoutOrder      = 0,   -- always first
        Parent           = TabBar,
    })

    -- Make sure the canvas always starts at the left on first open
    TabBar.CanvasPosition = Vector2.new(0, 0)

    -- Overflow fade + chevron — only visible when tabs don't fit
    local OverflowIndicator = Create("TextLabel", {
        Size             = UDim2.new(0, 28, 1, -2),
        Position         = UDim2.new(1, -28, 0, 1),
        BackgroundColor3 = Theme.Surface,
        Text             = ">",
        TextColor3       = Theme.TextMuted,
        TextSize         = 14,
        Font             = Enum.Font.GothamBold,
        TextXAlignment   = Enum.TextXAlignment.Right,
        Visible          = false,
        ZIndex           = 5,
        Parent           = ClipFrame,
    })
    -- Fade gradient on the chevron background
    Create("UIGradient", {
        Rotation    = 180,
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(0.4, 0),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Parent = OverflowIndicator,
    })

    -- Watch canvas width vs bar width — only enable scroll when truly overflowing
    -- Use AbsoluteSize change on the TabBar itself (fires after layout) for accuracy
    local function refreshTabScroll()
        -- AbsoluteContentSize already includes the 8px spacer frame
        local contentW = TabLayout.AbsoluteContentSize.X
        local barW     = TabBar.AbsoluteSize.X
        local over     = contentW > barW + 1
        TabBar.ScrollingEnabled     = over
        TabBar.ScrollBarThickness   = over and 2 or 0
        OverflowIndicator.Visible   = over
    end

    track(TabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshTabScroll))
    track(TabBar:GetPropertyChangedSignal("AbsoluteSize"):Connect(refreshTabScroll))

    -- ── Content Area ────────────────────────
    local ContentArea = Create("ScrollingFrame", {
        Name                 = "ContentArea",
        Size                 = UDim2.new(1, 0, 1, -116),
        Position             = UDim2.new(0, 0, 0, 82),
        BackgroundTransparency = 1,
        BorderSizePixel      = 0,
        ScrollBarThickness   = 3,
        ScrollBarImageColor3 = Theme.Accent,
        CanvasSize           = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize  = Enum.AutomaticSize.Y,
        ZIndex               = 3,
        Parent               = ClipFrame,
    })
    Create("UIPadding", {
        PaddingLeft   = UDim.new(0, 12),
        PaddingRight  = UDim.new(0, 12),
        PaddingTop    = UDim.new(0, 10),
        PaddingBottom = UDim.new(0, 10),
        Parent        = ContentArea,
    })
    Create("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding   = UDim.new(0, 4),
        Parent    = ContentArea,
    })

    -- ── Footer ──────────────────────────────
    local Footer = Create("Frame", {
        Name             = "Footer",
        Size             = UDim2.new(1, 0, 0, 34),
        Position         = UDim2.new(0, 0, 1, -34),
