    -- LEFT-aligned horizontal layout.
    -- NOTE: Do NOT put UIPadding on a ScrollingFrame with AutomaticCanvasSize —
    -- it gets included in the canvas measurement and creates phantom empty space.
    -- Use a leading spacer frame instead for the small left gap.
    local TabLayout = Create("UIListLayout", {
        FillDirection       = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Left,
        VerticalAlignment   = Enum.VerticalAlignment.Center,
        SortOrder           = Enum.SortOrder.LayoutOrder,
        Padding             = UDim.new(0, 0),
        Parent              = TabBar,
